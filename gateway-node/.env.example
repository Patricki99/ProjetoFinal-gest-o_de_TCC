PORT=3000
HOST=localhost
# Para aceitar acesso de outra maquina (ex.: navegador do orientador), use:
# HOST=0.0.0.0
ZMQ_HOST=localhost
# CORS "*" libera a interface (inclusive de outra maquina) no prototipo
CORS_ORIGIN=*
NODE_ENV=development

# ---- Multi-maquina: IP de cada servico que o gateway assina (se estiver em outra maquina) ----
# HOST_DOCUMENTOS=192.168.0.11
# HOST_IA=192.168.0.11
# HOST_AVALIACAO=192.168.0.11
# HOST_NOTIFICACAO=192.168.0.11
