# Banco (MySQL) - se ausente, os servicos usam fallback em memoria para demonstrar
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tcc_db

# Provedor de LLM:
#   simulado -> em processo (offline, zero setup)
#   http     -> consulta o stub local por HTTP (fiel a' seta do diagrama de sequencia)
#   ollama   -> modelo local via Ollama
LLM_PROVIDER=simulado
LLM_URL=http://localhost:5571/analisar
LLM_STUB_PORT=5571
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# ---- Multi-maquina (apresentacao) ----
# Por padrao tudo roda em localhost. Para distribuir os peers, defina o IP de cada
# servico NA MAQUINA QUE PRECISA SE CONECTAR A ELE. Exemplos:
# HOST_GATEWAY=192.168.0.10       # IP da maquina do gateway (usado pelos servicos documentos/avaliacao)
# HOST_DOCUMENTOS=192.168.0.10    # IP da maquina do servico de Documentos (usado pela IA)
# HOST_IA=192.168.0.11            # IP da maquina do servico de IA (usado por Notificacoes)
# HOST_AVALIACAO=192.168.0.11     # IP da maquina de Feedback e Avaliacao (usado pela IA)
# HOST_NOTIFICACAO=192.168.0.11
# LLM_URL=http://192.168.0.11:5571/analisar   # se o stub de LLM estiver em outra maquina
# Ou um unico IP para todos os peers remotos:
# ZMQ_HOST_DEFAULT=192.168.0.10
